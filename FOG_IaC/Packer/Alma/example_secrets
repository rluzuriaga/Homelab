#

#
# Proxmox Connection Settings
#
proxmox_api_url = "https://IP-OR-HOSTNAME:8006/api2/json"
proxmox_api_token_id = "USERNAME@REALM!TOKEN-NAME-HERE"
proxmox_api_token_secret = "TOKEN-SECRET-HERE"

#
# SSH creds
# Make sure that they are the same creds as what is in the http/ks.cfg file
# That file has the password hashed but this file would have it in clear text
#
ssh_username = "USERNAME"
ssh_password = "PASSWORD"

